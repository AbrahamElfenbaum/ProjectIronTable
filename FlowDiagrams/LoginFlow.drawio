<mxfile host="app.diagrams.net">
  <diagram name="Login Flow" id="login-flow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- STARTUP FLOW -->
        <mxCell id="2" value="App Launches" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="40" width="160" height="50" as="geometry" />
        </mxCell>

        <mxCell id="3" value="USessionInstance::Init()&#xa;&#xa;Tries to load UPlayerSave&#xa;(slot: &quot;PlayerIdentity&quot;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="60" y="130" width="200" height="70" as="geometry" />
        </mxCell>

        <mxCell id="4" value="Save exists and PlayerID valid?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="75" y="240" width="170" height="70" as="geometry" />
        </mxCell>

        <mxCell id="5" value="Generate FGuid::NewGuid()&#xa;Create new UPlayerSave&#xa;Save to disk" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="300" y="240" width="180" height="70" as="geometry" />
        </mxCell>

        <mxCell id="6" value="Store PlayerID on&#xa;USessionInstance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="75" y="350" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Startup arrows -->
        <mxCell id="7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="2" target="3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="3" target="4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="9" value="No" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="4" target="5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="10" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="4" target="6" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="11" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="5" target="6" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- SESSION LAUNCH FLOW -->
        <mxCell id="12" value="Player clicks campaign&#xa;in UCampaignManagerScreen" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="40" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="13" value="OnCampaignSelected()&#xa;&#xa;Gets USessionInstance&#xa;Reads PlayerID (FGuid)&#xa;Builds travel URL:&#xa;&quot;MapName?PlayerID=&lt;guid&gt;&quot;&#xa;Calls ServerTravel()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="550" y="140" width="220" height="120" as="geometry" />
        </mxCell>

        <mxCell id="14" value="Engine transitions all&#xa;clients to session level" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="565" y="300" width="190" height="60" as="geometry" />
        </mxCell>

        <mxCell id="15" value="ASessionGameMode::InitGame()&#xa;&#xa;Loads USessionSave using SessionID&#xa;Populates ASessionGameState with&#xa;host / GM / player ID lists" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="545" y="400" width="230" height="90" as="geometry" />
        </mxCell>

        <mxCell id="16" value="ASessionGameMode::PostLogin()&#xa;(runs once per connecting player)&#xa;&#xa;Parses PlayerID from OptionsString&#xa;Sets SessionPlayerID on PlayerState&#xa;Checks against GameState ID lists&#xa;Sets bIsHost / bIsGM flags&#xa;Adds player to active list in GameState" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="540" y="530" width="240" height="130" as="geometry" />
        </mxCell>

        <mxCell id="17" value="Player is in session&#xa;with correct role" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="575" y="700" width="170" height="60" as="geometry" />
        </mxCell>

        <!-- Session launch arrows -->
        <mxCell id="18" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="12" target="13" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="19" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="13" target="14" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="20" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="14" target="15" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="21" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="15" target="16" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="22" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="16" target="17" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Cross-flow: SessionInstance feeds into OnCampaignSelected -->
        <mxCell id="23" value="PlayerID available&#xa;for travel URL" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#999999;" edge="1" source="6" target="13" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="24" value="Legend" style="text;html=1;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="40" width="80" height="30" as="geometry" />
        </mxCell>
        <mxCell id="25" value="App startup" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="860" y="80" width="140" height="30" as="geometry" />
        </mxCell>
        <mxCell id="26" value="Engine / level transition" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="860" y="120" width="140" height="30" as="geometry" />
        </mxCell>
        <mxCell id="27" value="Start / end state" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="860" y="160" width="140" height="30" as="geometry" />
        </mxCell>
        <mxCell id="28" value="Success state" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="860" y="200" width="140" height="30" as="geometry" />
