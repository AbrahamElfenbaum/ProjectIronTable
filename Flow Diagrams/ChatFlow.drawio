        <!-- CHANNEL MANAGEMENT -->
        <mxCell id="30" value="CreateChannel(Participants[])" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
