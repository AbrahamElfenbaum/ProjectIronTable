        <mxCell id="41" value="SetUserFocus(PC) on EditableText&#xa;bChatFocused = true&#xa;SetIsEnabled(true)&#xa;SetInputMode(FInputModeUIOnly)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
