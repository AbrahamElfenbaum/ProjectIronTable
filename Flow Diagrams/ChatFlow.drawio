<mxfile host="app.diagrams.net">
  <diagram name="Chat Flow" id="chat-flow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- SECTION LABELS -->
        <mxCell id="s1" value="SENDING A MESSAGE" style="text;html=1;fontStyle=1;fontSize=13;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="220" height="30" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="CHANNEL MANAGEMENT" style="text;html=1;fontStyle=1;fontSize=13;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="20" width="220" height="30" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="FOCUS / EXIT" style="text;html=1;fontStyle=1;fontSize=13;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1200" y="20" width="180" height="30" as="geometry" />
        </mxCell>

        <!-- SEND FLOW -->
        <mxCell id="10" value="Player types message&#xa;in EditableText" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="180" height="50" as="geometry" />
        </mxCell>

        <mxCell id="11" value="Press Enter&#xa;OnTextCommitted()&#xa;&#xa;Sets bPendingRefocus = true&#xa;before FocusChat() to absorb&#xa;Slate&#39;s spurious OnUserMovedFocus" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="170" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="12" value="Parse words for @mentions&#xa;→ Recipients[]&#xa;→ Message (remaining words)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="40" y="260" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="13" value="Active channel is private&#xa;and no @mentions typed?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="55" y="360" width="190" height="70" as="geometry" />
        </mxCell>

        <mxCell id="14" value="Auto-fill Recipients&#xa;from ActiveChannel.Participants&#xa;(minus sender)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="300" y="360" width="200" height="70" as="geometry" />
        </mxCell>

        <mxCell id="15" value="SendChatMessageOnServer()&#xa;[Server RPC]&#xa;&#xa;Format: &quot;PlayerName: Message&quot;&#xa;&#xa;After routing: persists to USessionSave&#xa;Key = sorted pipe-joined Participants&#xa;FindOrAdd ChatLog entry → save slot" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="60" y="470" width="240" height="110" as="geometry" />
        </mxCell>

        <mxCell id="16" value="Recipients empty?&#xa;(public message)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="75" y="580" width="170" height="70" as="geometry" />
        </mxCell>

        <mxCell id="17" value="AddChatMessageOnOwningClient()&#xa;[Client RPC → ALL players]&#xa;bIsSender = (client == sender)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="40" y="690" width="230" height="70" as="geometry" />
        </mxCell>

        <mxCell id="18" value="AddChatMessageOnOwningClient()&#xa;[Client RPC → sender + recipients only]&#xa;bIsSender = (client == sender)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="310" y="690" width="250" height="70" as="geometry" />
        </mxCell>

        <mxCell id="19" value="ChatBox::AddChatMessage()&#xa;&#xa;Calls FindOrCreateChannel(Participants)&#xa;Num() check first, then content match&#xa;Creates channel + tab if no match found" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="150" y="810" width="250" height="80" as="geometry" />
